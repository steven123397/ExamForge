# 在服务器上复制为 .env.production，替换所有尖括号占位符，
# 然后执行 chmod 600 .env.production，仅允许文件所有者读写。
COMPOSE_PROJECT_NAME=examforge

# 所有镜像必须包含不可变 sha256 digest，禁止使用 latest。
EXAMFORGE_API_IMAGE=ccr.ccs.tencentyun.com/examforge/api@sha256:<64-hex-digest>
EXAMFORGE_WEB_IMAGE=ccr.ccs.tencentyun.com/examforge/web@sha256:<64-hex-digest>
EXAMFORGE_WORKER_IMAGE=ccr.ccs.tencentyun.com/examforge/worker@sha256:<64-hex-digest>
EXAMFORGE_SCHEDULER_IMAGE=ccr.ccs.tencentyun.com/examforge/scheduler@sha256:<64-hex-digest>
EXAMFORGE_POSTGRES_IMAGE=postgres@sha256:<64-hex-digest>
EXAMFORGE_REDIS_IMAGE=redis@sha256:<64-hex-digest>

EXAMFORGE_PUBLIC_ORIGIN=https://examforge.site
EXAMFORGE_TRUSTED_ORIGINS=https://examforge.site
EXAMFORGE_API_PORT=4000
EXAMFORGE_WEB_PORT=3000

# PostgreSQL/Redis 在线数据保留在 ext4 数据盘；COS 仅用于异机备份。
EXAMFORGE_DATA_DIR=/srv/data/hot/examforge
EXAMFORGE_BACKUP_DIR=/srv/data/hot/examforge/backups/postgres
EXAMFORGE_OFFSITE_BACKUP_DIR=/srv/data/cos/examforge/postgres
EXAMFORGE_BACKUP_RETENTION_DAYS=14
EXAMFORGE_MAX_BACKUP_AGE_SECONDS=93600
EXAMFORGE_MIN_FREE_KIB=5242880
EXAMFORGE_CERTIFICATE_WARNING_DAYS=21
EXAMFORGE_TLS_CERTIFICATE_PATH=/etc/letsencrypt/live/examforge.site/fullchain.pem

POSTGRES_USER=examforge
POSTGRES_PASSWORD=<generate-url-safe-password-at-least-24-characters>
POSTGRES_DB=examforge

EXAMFORGE_ADMIN_PASSWORD=<generate-password-at-least-20-characters>
EXAMFORGE_OPERATOR_PASSWORD=<generate-password-at-least-20-characters>
EXAMFORGE_TEACHER_PASSWORD=<generate-password-at-least-20-characters>
EXAMFORGE_STUDENT_PASSWORD=<generate-password-at-least-20-characters>
EXAMFORGE_SESSION_COOKIE_NAME=examforge_session
EXAMFORGE_SESSION_COOKIE_SECURE=true
EXAMFORGE_SESSION_TTL_SECONDS=43200
LOG_LEVEL=info
