# Docker Compose 会自动读取根目录 .env；本地 npm run dev 需要显式导出变量。
# 以下凭据仅用于本机演示，不要在此文件中填写真实密码或 token。
POSTGRES_USER=examforge
POSTGRES_PASSWORD=examforge-local-only
POSTGRES_DB=examforge
POSTGRES_PORT=5432
REDIS_PORT=6379

# 宿主机进程使用 localhost；Compose 内部由配置生成 postgres:5432 地址。
DATABASE_URL=postgres://examforge:examforge-local-only@localhost:5432/examforge
REDIS_URL=redis://localhost:6379/0

API_HOST=0.0.0.0
API_PORT=4000
EXAMFORGE_DEPLOYMENT_MODE=demo
WEB_PORT=3000
SCHEDULER_PORT=8000
LOG_LEVEL=info
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
SCHEDULER_TRANSPORT=cli
SCHEDULER_BASE_URL=http://localhost:8000
SCHEDULER_HTTP_TIMEOUT_MS=35000
SCHEDULER_PYTHON=uv
SCHEDULER_CPUS=2.0
SCHEDULER_MEMORY_LIMIT=2g
SCHEDULER_PIDS_LIMIT=256
REDIS_CPUS=0.5
REDIS_MEMORY_LIMIT=256m
REDIS_PIDS_LIMIT=128
PUBLISHER_CPUS=0.5
PUBLISHER_MEMORY_LIMIT=384m
PUBLISHER_PIDS_LIMIT=128
PUBLISHER_HEALTH_PORT=4010
WORKER_CPUS=1.0
WORKER_MEMORY_LIMIT=1g
WORKER_PIDS_LIMIT=192
WORKER_HEALTH_HOST=0.0.0.0
WORKER_HEALTH_PORT=4011
WORKER_ROLE=worker
OUTBOX_BATCH_SIZE=25
OUTBOX_POLL_INTERVAL_MS=500
WORKER_CONCURRENCY=1
WORKER_CANCELLATION_POLL_INTERVAL_MS=250
WORKER_LOCK_DURATION_MS=30000
WORKER_STALLED_INTERVAL_MS=30000

# 本地账户只在对应密码显式配置时初始化。复制后必须自行填写，不提供默认密码。
EXAMFORGE_ADMIN_PASSWORD=
EXAMFORGE_OPERATOR_PASSWORD=
EXAMFORGE_TEACHER_PASSWORD=
EXAMFORGE_STUDENT_PASSWORD=
EXAMFORGE_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
EXAMFORGE_SESSION_COOKIE_SECURE=false
EXAMFORGE_SESSION_TTL_SECONDS=43200

COMPOSE_PROJECT_NAME=examforge
E2E_API_BASE_URL=http://127.0.0.1:4000
E2E_WEB_BASE_URL=http://127.0.0.1:3000
E2E_SCHEDULER_BASE_URL=http://127.0.0.1:8000
# DEMO_RUN_FAULT_DRILLS=0
# KEEP_DEMO_STACK=1
