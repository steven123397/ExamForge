# Docker Compose 会自动读取根目录 .env；本地 npm run dev 需要显式导出变量。
# 以下凭据仅用于本机演示，不要在此文件中填写真实密码或 token。
POSTGRES_USER=examforge
POSTGRES_PASSWORD=examforge-local-only
POSTGRES_DB=examforge
POSTGRES_PORT=5432

# 宿主机进程使用 localhost；Compose 内部由配置生成 postgres:5432 地址。
DATABASE_URL=postgres://examforge:examforge-local-only@localhost:5432/examforge

API_HOST=0.0.0.0
API_PORT=4000
WEB_PORT=3000
LOG_LEVEL=info
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
SCHEDULER_PYTHON=uv

COMPOSE_PROJECT_NAME=examforge
E2E_API_BASE_URL=http://127.0.0.1:4000
E2E_WEB_BASE_URL=http://127.0.0.1:3000
# KEEP_DEMO_STACK=1
