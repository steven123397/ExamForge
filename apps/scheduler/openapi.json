            "type": "array"
          },
          "message": {
            "title": "Message",
            "type": "string"
          },
          "severity": {
            "enum": [
              "error",
              "warning"
            ],
            "title": "Severity",
            "type": "string"
          },
          "suggestion": {
            "title": "Suggestion",
            "type": "string"
          },
          "type": {
            "title": "Type",
            "type": "string"
          }
        },
        "required": [
          "type",
          "severity",
          "affected_ids",
          "message",
          "suggestion"
        ],
