          },
          "room_id": {
            "minLength": 1,
            "title": "Room Id",
            "type": "string"
          },
          "teacher_ids": {
            "items": {
              "type": "string"
            },
            "title": "Teacher Ids",
            "type": "array"
          },
          "time_slot_id": {
            "minLength": 1,
            "title": "Time Slot Id",
            "type": "string"
          }
        },
        "required": [
          "exam_task_id",
          "room_id",
          "time_slot_id"
        ],
        "title": "AssignmentModel",
        "type": "object"
      },
      "ConflictRecordModel": {
        "additionalProperties": false,
        "properties": {
          "affected_ids": {
            "items": {
              "type": "string"
            },
